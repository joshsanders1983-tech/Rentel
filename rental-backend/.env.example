PORT=4000
# Supabase = Postgres. Rentel talks to your database through this URL (Prisma). You do not need @supabase/supabase-js for normal app data.
# Supabase Dashboard → Project Settings → Database → Connection string → URI. Prefer the Direct connection (port 5432) for prisma migrate deploy.
# Example shape (use your project host and password): postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Optional — for @supabase/supabase-js (Auth, Storage, Realtime). Project Settings → API → Project URL + anon public key.
# Do not commit real keys. Same names as the Next.js template, but without NEXT_PUBLIC_ (this is server-only).
SUPABASE_URL=
SUPABASE_ANON_KEY=

ADMIN_PASSWORD=change-me
