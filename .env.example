PORT=4000
# Supabase Postgres via Prisma — use the Supavisor pooler hostnames (IPv4 + IPv6). The direct host
# db.<project>.supabase.co:5432 is often IPv6-only and fails from hosts like Render.
# Dashboard → Connect → copy Session + Transaction strings. Official guide:
# https://supabase.com/docs/guides/database/prisma

# Runtime (Prisma Client): Transaction mode — port 6543, add pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations (prisma migrate): Session mode — port 5432, same pooler hostname
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Optional — @supabase/supabase-js (Auth, Storage, Realtime). Project Settings → API.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

ADMIN_PASSWORD=change-me
